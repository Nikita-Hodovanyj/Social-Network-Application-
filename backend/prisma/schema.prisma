generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model user_app_user {
  id                                                                  BigInt                           @id @default(autoincrement())
  password                                                            String                           @db.VarChar(128)
  last_login                                                          DateTime?                        @db.Timestamptz(6)
  is_superuser                                                        Boolean
  first_name                                                          String                           @db.VarChar(150)
  last_name                                                           String                           @db.VarChar(150)
  is_staff                                                            Boolean
  is_active                                                           Boolean
  date_joined                                                         DateTime                         @db.Timestamptz(6)
  username                                                            String?                          @unique(map: "user_app_user_username_e45e0961_uniq") @db.VarChar(150)
  email                                                               String                           @unique @db.VarChar(254)
  chat_app_chat                                                       chat_app_chat[]
  chat_app_chat_users                                                 chat_app_chat_users[]
  chat_app_message                                                    chat_app_message[]
  chat_app_message_readers                                            chat_app_message_readers[]
  django_admin_log                                                    django_admin_log[]
  post_app_post                                                       post_app_post[]
  post_app_postheart                                                  post_app_postheart[]
  post_app_postlike                                                   post_app_postlike[]
  post_app_postview                                                   post_app_postview[]
  profile_app_profile                                                 profile_app_profile?
  user_app_friendship_user_app_friendship_from_user_idTouser_app_user user_app_friendship[]            @relation("user_app_friendship_from_user_idTouser_app_user")
  user_app_friendship_user_app_friendship_to_user_idTouser_app_user   user_app_friendship[]            @relation("user_app_friendship_to_user_idTouser_app_user")
  user_app_user_groups                                                user_app_user_groups[]
  user_app_user_user_permissions                                      user_app_user_user_permissions[]

  @@index([email], map: "user_app_user_email_e59b5739_like")
  @@index([username], map: "user_app_user_username_e45e0961_like")
}

model profile_app_profile {
  id                 BigInt              @id @default(autoincrement())
  birth_date         DateTime?           @db.Date
  signature          String?             @db.VarChar(100)
  avatar             String?             @db.VarChar(100)
  pseudonym          String?             @db.VarChar(50)
  is_text_signature  Boolean
  is_image_signature Boolean
  user_id            BigInt?             @unique
  profile_app_album  profile_app_album[]
  user_app_user      user_app_user?      @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "profile_app_profile_user_id_296a7b55_fk_user_app_user_id")
}

model user_app_friendship {
  id                                                            BigInt        @id @default(autoincrement())
  status                                                        String        @db.VarChar(10)
  created_at                                                    DateTime      @db.Timestamptz(6)
  from_user_id                                                  BigInt
  to_user_id                                                    BigInt
  user_app_user_user_app_friendship_from_user_idTouser_app_user user_app_user @relation("user_app_friendship_from_user_idTouser_app_user", fields: [from_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_app_friendship_from_user_id_e1d46b12_fk_user_app_user_id")
  user_app_user_user_app_friendship_to_user_idTouser_app_user   user_app_user @relation("user_app_friendship_to_user_idTouser_app_user", fields: [to_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_app_friendship_to_user_id_f5d68c80_fk_user_app_user_id")

  @@unique([from_user_id, to_user_id], map: "user_app_friendship_from_user_id_to_user_id_1917f941_uniq")
  @@index([from_user_id], map: "user_app_friendship_from_user_id_e1d46b12")
  @@index([to_user_id], map: "user_app_friendship_to_user_id_f5d68c80")
}

model profile_app_album {
  id                     BigInt                   @id @default(autoincrement())
  name                   String                   @db.VarChar(100)
  theme                  String?                  @db.VarChar(50)
  year                   Int?
  is_shown               Boolean
  is_default             Boolean
  created_at             DateTime                 @db.Timestamptz(6)
  profile_id             BigInt
